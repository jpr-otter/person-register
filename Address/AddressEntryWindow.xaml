<Window x:Class="PersonRegister.AddressEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Address Entry" Height="350" Width="400">
    <Grid>
        <StackPanel Orientation="Vertical" Margin="10">

            <TextBlock Text="Category:" FontWeight="Bold"/>
            <ComboBox x:Name="CategoryComboBox" Width="200" HorizontalAlignment="Left" Margin="0,5,5,5">
                <ComboBoxItem Content="Home-Address"/>
                <ComboBoxItem Content="Office-Address"/>                
            </ComboBox>

            <TextBlock Text="Floor:" FontWeight="Bold"/>
            <TextBox x:Name="FloorTextBox" />

            <TextBlock Text="Building Number:" FontWeight="Bold"/>
            <TextBox x:Name="BuildingNumberTextBox" />

            <TextBlock Text="Street:" FontWeight="Bold"/>
            <TextBox x:Name="StreetTextBox" />

            <TextBlock Text="Postal Code:" FontWeight="Bold"/>
            <TextBox x:Name="PostalCodeTextBox" />

            <TextBlock Text="State:" FontWeight="Bold"/>
            <TextBox x:Name="StateTextBox" />

            <TextBlock Text="Country:" FontWeight="Bold"/>
            <TextBox x:Name="CountryTextBox" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <Button Content="OK" Width="100" Click="OK_Click"/>
                <Button Content="Cancel" Width="100" Margin="10,0,0,0" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
