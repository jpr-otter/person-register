<Window x:Class="PersonRegister.CustomFieldEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Field Entry" Height="200" Width="400">
    <StackPanel Margin="10">
        <TextBlock Text="Custom Field Name:" />
        <TextBox x:Name="FieldNameTextBox" Width="300" Margin="0,0,0,10" />

        <TextBlock Text="Custom Field Value:" />
        <TextBox x:Name="FieldValueTextBox" Width="300" Margin="0,0,0,10" />

        <Button Content="OK" Click="AddCustomField_Click" Width="150" Margin="0,0,0,0" />
        <Button Content="Cancel" Click="Cancel_Click" Width="150" Margin="0,5,0,0" />
    </StackPanel>
</Window>
