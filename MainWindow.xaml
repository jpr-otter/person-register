<Window x:Class="PersonRegister.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:local="clr-namespace:PersonRegister"
        Title="Person Register" 
        Height="500" 
        Width="750">
    <Window.Resources>
        

        
        <Style x:Key="TextBlockStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="PeopleDataGrid" 
                  Grid.Row="0" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="PeopleListBox_SelectionChanged"
                  Margin="10">
            <DataGrid.Resources>
                <Style TargetType="DataGridRow">
                    <Setter Property="MinHeight" Value="50"/>
                    <Setter Property="Height" Value="Auto"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FFD5D5D5"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" 
                                  Binding="{Binding Id}" 
                                  Width="100"/>
                <DataGridTextColumn Header="Last Name" 
                                  Binding="{Binding LastName}" 
                                  Width="120"/>
                <DataGridTextColumn Header="First Name" 
                                  Binding="{Binding Name}" 
                                  Width="120"/>
                <DataGridTemplateColumn Header="Addresses" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding Addresses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Style="{StaticResource TextBlockStyle}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Phone Numbers" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding PhoneNumbers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Style="{StaticResource TextBlockStyle}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Custom Fields" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding CustomFields}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Style="{StaticResource TextBlockStyle}" Margin="5"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Separator -->
        <Border Grid.Row="1" 
                Height="2" 
                Background="Gray" 
                Margin="10,0"/>

        <!-- Control Panel -->
        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="10">
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Button Content="Add Person" 
                        Click="AddPerson_Click" 
                        Margin="0,0,10,0"/>
                <Button Content="Edit Person" 
                        Click="EditPerson_Click" 
                        Margin="0,0,10,0"/>
                <Button Content="Delete Person" 
                        Click="DeletePerson_Click" 
                        Margin="0,0,10,0"/>
            </StackPanel>

            <!-- StackPanel for Save and Load Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5">
                <Label Content="Enter file path here:" 
                       VerticalAlignment="Center" 
                       Margin="0,0,35,0"/>
                <Button Content="Save Data" 
                        Click="Save_Click" 
                        Margin="0,0,10,0"/>
                <Button Content="Load Data" 
                        Click="Load_Click"/>
            </StackPanel>

            
            <TextBox x:Name="FileNameTextBox" 
                     Width="270" 
                     HorizontalAlignment="Right" 
                     Margin="0,5"/>
        </StackPanel>
    </Grid>
</Window>
